{
  "manifest_version": 3,
  "name": "Pi Browser Bridge",
  "version": "0.1.0",
  "description": "Connects a Chromium browser to pi through a localhost bridge using chrome.debugger.",
  "permissions": ["tabs", "storage", "debugger"],
  "host_permissions": ["http://127.0.0.1/*", "http://localhost/*"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "options_page": "options.html",
  "action": {
    "default_title": "Pi Browser Bridge"
  }
}
