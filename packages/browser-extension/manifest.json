{
  "manifest_version": 3,
  "name": "Onhand Browser Bridge",
  "version": "0.1.0",
  "description": "Connects a Chromium browser to Onhand through a localhost bridge.",
  "minimum_chrome_version": "116",
  "permissions": ["tabs", "storage", "debugger", "sidePanel", "offscreen", "scripting"],
  "host_permissions": ["http://127.0.0.1/*", "http://localhost/*", "http://*/*", "https://*/*"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "options_page": "options.html",
  "action": {
    "default_title": "Onhand Browser Bridge"
  },
  "web_accessible_resources": [
    {
      "resources": ["vendor/*", "fonts/*"],
      "matches": ["<all_urls>"]
    }
  ]
}
